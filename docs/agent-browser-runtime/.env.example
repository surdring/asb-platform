# Host-facing ports are bound to 127.0.0.1 only.
BROKER_HOST_PORT=17890
CDP_HOST_PORT=19223
NOVNC_HOST_PORT=16080

# Optional build-time mirrors. Leave the defaults unless your Docker build
# environment needs alternate package/module mirrors.
ALPINE_MIRROR=https://dl-cdn.alpinelinux.org/alpine
DEBIAN_MIRROR=http://deb.debian.org/debian
DEBIAN_SECURITY_MIRROR=http://deb.debian.org/debian-security
GOPROXY=https://proxy.golang.org,direct

# Runtime browser defaults
SCREEN_WIDTH=1440
SCREEN_HEIGHT=1000
SCREEN_DEPTH=24
FINGERPRINT_SEED=1000
BRS_RUNTIME_PRESET=chrome124-macos
# Advertised browser fingerprint profile, not the host OS. Supported: windows, macos, linux.
FINGERPRINT_PLATFORM=macos
BRS_FINGERPRINT_PLATFORM=macos
BRS_CHROME_MAJOR=124
# Optional host directory containing fingerprint-chromium's chrome-wrapper or chrome.
# Enable with:
# docker compose -f docker-compose.yml -f docker-compose.fingerprint.yml up --build -d
BRS_FINGERPRINT_CHROMIUM_HOST_PATH=
BROWSER_TIMEZONE=America/Los_Angeles
BOT_HUMANIZE_LEVEL=enhanced
BOT_RUNTIME_SIGNATURE=agent-browser-runtime:v11-profile-preserve-extension-refresh|chrome=compose|profile=/data/user-data
BRS_RESET_PROFILE_ON_SIGNATURE_CHANGE=0

# Platform pacing defaults for common high-friction social surfaces.
BRS_PLATFORM_COOLDOWN_ENABLED=1
BRS_PLATFORM_COOLDOWN_REDDIT_SECONDS=45
BRS_PLATFORM_COOLDOWN_FACEBOOK_SECONDS=60
BRS_PLATFORM_COOLDOWN_LINKEDIN_SECONDS=180
BRS_PLATFORM_COOLDOWN_INSTAGRAM_SECONDS=240
BRS_PLATFORM_COOLDOWN_MANUAL_CHALLENGE_SECONDS=300

# Default browser consistency policy. Enabled by default for all regular http/https tabs.
BRS_STEALTH_ENABLED=1
BRS_STEALTH_PROFILE=chrome124-macos
BRS_STEALTH_EXCLUDED_HOSTS=accounts.google.com
BRS_GENERATE_FINGERPRINT_ENABLED=1
BRS_FINGERPRINT_SEED=
BRS_FINGERPRINT_PLATFORM=macos
BRS_CHROME_MAJOR=124
BRS_CHROME_FULL_VERSION=
BRS_BROWSER_BRAND=Google Chrome
BRS_FINGERPRINT_HEADERS_ENABLED=1
BRS_FINGERPRINT_PATCHES_ENABLED=1
BRS_CANVAS_NOISE_ENABLED=1
BRS_AUDIO_NOISE_ENABLED=1
BRS_ACCEPT_LANGUAGE=en-US,en;q=0.9
BRS_LOCALE=en-US
BRS_STEALTH_TIMEZONE=America/Los_Angeles
BRS_USER_AGENT=
BRS_PLATFORM=
BRS_WEBGL_VENDOR=
BRS_WEBGL_RENDERER=
BRS_EXTRA_HTTP_HEADERS_JSON=

# Startup-level proxy/TLS gateway integration. Compose provides a local
# tls-gateway service by default; leave these values as-is to route Chromium
# through it at launch time and disable QUIC on that proxied path.
# BROWSER_PROXY_SERVER=http://proxy:8080
BROWSER_PROXY_BYPASS_LIST=127.0.0.1,localhost,::1,broker,chrome-runtime,tls-gateway
BRS_TLS_GATEWAY_ENABLED=1
BRS_TLS_GATEWAY_PROXY_SERVER=http://tls-gateway:8080
BRS_TLS_GATEWAY_BASE_URL=http://tls-gateway:8080
BRS_TLS_GATEWAY_HEALTH_URL=
BRS_TLS_GATEWAY_STATS_URL=
BRS_TLS_GATEWAY_HEALTH_PATH=/health
BRS_TLS_GATEWAY_STATS_PATH=/stats
BRS_TLS_GATEWAY_TIMEOUT_MS=1500
BRS_TLS_GATEWAY_LOG_LEVEL=info
BRS_TLS_GATEWAY_PROFILE=Chrome-124-macOS
BRS_TLS_GATEWAY_ENABLE_SESSIONS=true
BRS_TLS_GATEWAY_SESSION_TTL=1h
BRS_TLS_GATEWAY_SESSION_ROUTING_POLICY=sticky
BRS_TLS_GATEWAY_OUTBOUND_IPS=
BRS_TLS_GATEWAY_ENABLE_PROXY_CHAIN=false
BRS_TLS_GATEWAY_PROXY_CHAIN=

# Internal broker WS consumed by the companion extension. Keep this at 17890 unless
# extension/background.js and docker-compose.yml are updated together.
BROWSER_RUNTIME_BROKER_WS=ws://broker:17890/extension
