{
  "manifest_version": 3,
  "name": "ASB Anti-Fingerprint",
  "version": "1.0.0",
  "description": "Browser anti-fingerprint baseline for ASB container sessions.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}