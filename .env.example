# ── 服务端口 ──
BROKER_HOST_PORT=8787
CDP_HOST_PORT=9223
NOVNC_HOST_PORT=16080

# ── 反检测 ──
ASB_STEALTH_ENABLED=1
ASB_STEALTH_EXCLUDED_HOSTS=
ASB_CANVAS_NOISE_ENABLED=1
ASB_AUDIO_NOISE_ENABLED=1
ASB_WEBGL_VENDOR=
ASB_WEBGL_RENDERER=

# ── CDP 覆盖 ──
ASB_CDP_ACCEPT_LANGUAGE=en-US,en;q=0.9
ASB_CDP_USER_AGENT=
ASB_CDP_PLATFORM=
ASB_CDP_TIMEZONE=
ASB_CDP_LOCALE=

# ── 人化操作 ──
ASB_HUMANIZE_LEVEL=standard

# ── 平台冷却 ──
ASB_COOLDOWN_ENABLED=1
ASB_COOLDOWN_REDDIT_SECONDS=45
ASB_COOLDOWN_FACEBOOK_SECONDS=60
ASB_COOLDOWN_LINKEDIN_SECONDS=180
ASB_COOLDOWN_INSTAGRAM_SECONDS=240
ASB_COOLDOWN_MANUAL_CHALLENGE_SECONDS=300

# ── noVNC ──
ASB_VNC_ENABLED=1
ASB_VNC_PORT=5900
ASB_NOVNC_PORT=6080
SCREEN_WIDTH=1440
SCREEN_HEIGHT=1000
SCREEN_DEPTH=24

# ── 指纹种子 ──
ASB_FINGERPRINT_SEED=
ASB_FINGERPRINT_PLATFORM=macos
ASB_CHROME_MAJOR=